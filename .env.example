# Copie para .env e ajuste.
PORT=3000
# Gere uma chave aleatoria longa: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-esta-chave-por-uma-string-aleatoria-bem-longa

# ---- Persistencia dos dados ----
# OPCAO A (recomendada p/ nuvem): banco MongoDB permanente. Cole aqui a connection string do MongoDB Atlas.
# Enquanto esta variavel existir, o app grava no banco (dados nunca se perdem em redeploys).
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=radar_financeiro

# OPCAO B (padrao local): se NAO houver MONGODB_URI, grava em arquivo ./data/radar.json
DATA_DIR=./data
